# Local session and workstation files
.agents/
.codex
frontend/.codex
.local/
.archive/

# Python cache
__pycache__/
*.py[cod]

# Backup and ad-hoc log files
*.bak
nohup.out
backups/

# OS/editor noise
.DS_Store
Thumbs.db

# Runtime output
data/plugins/
data/plugins/**
data/logs/**
data/tasks/**
data/uploads/**
data/artifacts/**
data/reports/**
data/db/*.db
data/db/*.sqlite
data/db/*.sqlite3

# Keep runtime directories in the tree
!data/logs/.gitkeep
!data/tasks/.gitkeep
!data/uploads/.gitkeep
!data/artifacts/.gitkeep
!data/reports/.gitkeep
!data/db/.gitkeep
